{
  "uid": "nexusmind-retrieval",
  "title": "NexusMind — Retrieval",
  "tags": ["nexusmind"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Retrieval Latency (total stage)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "nexusmind-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(nexusmind_retrieval_duration_seconds_bucket{stage=\"total\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nexusmind_retrieval_duration_seconds_bucket{stage=\"total\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(nexusmind_retrieval_duration_seconds_bucket{stage=\"total\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 2,
      "title": "Stage Latency p95 (vector / bm25 / rrf / rerank)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "nexusmind-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(nexusmind_retrieval_duration_seconds_bucket[5m])))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Search Cache Hit Rate (1h)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "nexusmind-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.4 },
            { "color": "green", "value": 0.7 }
          ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(nexusmind_retrieval_cache_hits_total[1h])) / clamp_min(sum(rate(nexusmind_retrieval_cache_hits_total[1h])) + sum(rate(nexusmind_retrieval_cache_misses_total[1h])), 1)"
        }
      ]
    },
    {
      "id": 4,
      "title": "LLM Call Latency p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "nexusmind-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(nexusmind_llm_duration_seconds_bucket[5m])))",
          "legendFormat": "{{model}}"
        }
      ]
    }
  ]
}
