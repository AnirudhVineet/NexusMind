{
  "uid": "nexusmind-system",
  "title": "NexusMind — System",
  "tags": ["nexusmind"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "description": "Requires windows_exporter (job 'windows').",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "nexusmind-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg(rate(windows_cpu_time_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory Available",
      "description": "Requires windows_exporter.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "nexusmind-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "windows_memory_available_bytes",
          "legendFormat": "available"
        }
      ]
    },
    {
      "id": 3,
      "title": "Logical Disk Free",
      "description": "Requires windows_exporter.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "nexusmind-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "windows_logical_disk_free_bytes",
          "legendFormat": "{{volume}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Knowledge Graph Size",
      "description": "Entities and edges currently stored (from the NexusMind API).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "nexusmind-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "nexusmind_graph_entities_total",
          "legendFormat": "entities"
        },
        {
          "refId": "B",
          "expr": "sum(nexusmind_graph_edges_total)",
          "legendFormat": "edges"
        }
      ]
    }
  ]
}
