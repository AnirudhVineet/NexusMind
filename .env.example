# --- Database (native Postgres on localhost) ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nexusmind
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5432/nexusmind

# --- Cache + Broker (native Redis or Memurai on localhost) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Object storage: local filesystem ---
STORAGE_DIR=./data/files

# --- AI: LLM (Groq, OpenAI-compatible — Phase 1 default for /qa) ---
GROQ_API_KEY=gsk-replace-me
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1

# --- AI: Local LLM (Ollama — Phase 2 NER/relations/intelligence) ---
LLM_PROVIDER=groq
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_PRIMARY=qwen2.5:7b-instruct
OLLAMA_MODEL_FALLBACK=llama3.1:8b
OLLAMA_JSON_MODE_TIMEOUT_S=60
MODELS_LOCK_PATH=models.lock

# --- AI: Embeddings (Google Gemini) ---
GEMINI_API_KEY=replace-me
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

# --- Phase 2: NER pipeline ---
ENTITY_DEDUP_COSINE_THRESHOLD=0.92
ENTITY_DEDUP_FUZZ_THRESHOLD=85
ENTITY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_trf
GLINER_MODEL=urchade/gliner_medium-v2.1
GLINER_LABELS=concept,tool,method,metric

# --- Phase 2: Relation extraction ---
RELATION_MIN_CONFIDENCE=0.7
RELATION_TOKEN_BUDGET=50000
RELATION_QUEUE_BACKPRESSURE_DEPTH=100

# --- Phase 2: Document intelligence ---
INTELLIGENCE_MAP_REDUCE_TOKEN_THRESHOLD=8000

# --- Retrieval thresholds ---
SEARCH_TOP_K_DEFAULT=5
QA_NO_SOURCE_THRESHOLD=0.6
SEARCH_LOW_CONFIDENCE_THRESHOLD=0.5

# --- Phase 3.1: Hybrid retrieval ---
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-base
BM25_TOP_K=50
VECTOR_TOP_K=50
RRF_K=60
RERANK_TOP_K=10
SEARCH_CACHE_TTL_SECONDS=300

# --- Phase 3.3: Audio upload limit ---
AUDIO_MAX_UPLOAD_BYTES=524288000

# --- Auth ---
JWT_SECRET=replace-with-32-byte-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=3600

# --- Limits ---
MAX_UPLOAD_BYTES=52428800
ALLOWED_MIME_TYPES=application/pdf,text/plain,text/markdown

# --- Frontend ---
NEXTAUTH_SECRET=replace-with-32-byte-random-string
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Observability ---
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
METRICS_TOKEN=
LOG_LEVEL=INFO
ENVIRONMENT=development
